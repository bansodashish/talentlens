# ── Core ─────────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production
JWT_SECRET=change_this_in_production
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=replace-me-with-64-char-hex-openssl-rand-hex-32
DB_PATH=../db/talentlens.db

# ── CORS (production) ─────────────────────────────────────────────────────────
# Set to your public domain so API requests from the browser are accepted.
ALLOWED_ORIGIN=https://talentlenses.leedscrownbridge.co.uk

# ── CV Matching (OpenAI — optional) ──────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── OpenClaw Local Model (optional, privacy-first) ───────────────────────────
# OpenAI-compatible local endpoint, for example Ollama/OpenClaw/vLLM
OPENCLAW_LOCAL_BASE_URL=http://127.0.0.1:11434/v1
OPENCLAW_LOCAL_MODEL=qwen2.5:7b-instruct
# Some local endpoints require a bearer token value. If not, keep any placeholder.
OPENCLAW_LOCAL_API_KEY=local-dev-key
OPENCLAW_LOCAL_TIMEOUT_MS=180000
OPENCLAW_LOCAL_MAX_TOKENS=2048

# ── Candidate Scraper (Apify — optional) ─────────────────────────────────────
APIFY_TOKEN=apify_api_...
APIFY_ACTOR_ID=your_actor_id
# APIFY_TASK_ID=your_task_id  (use instead of ACTOR_ID if using a saved task)

# Platform-specific Apify actor IDs
APIFY_LINKEDIN_ACTOR_ID=harvestapi~linkedin-profile-search
APIFY_CVLIBRARY_ACTOR_ID=your_cvlibrary_actor_id

# ── Apollo People Search (optional) ──────────────────────────────────────────
# Server-wide fallback key. Users can also set a personal key under Profile → API Keys.
APOLLO_API_KEY=your_apollo_api_key

# ── Google Sheets Export (optional) ──────────────────────────────────────────
GOOGLE_SHEET_ID=your_sheet_id_from_url
GOOGLE_SERVICE_ACCOUNT_BASE64=base64_encoded_service_account_json
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
